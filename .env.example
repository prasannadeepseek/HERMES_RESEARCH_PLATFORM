# LLM Engine Configuration
# Example for OpenRouter
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key
MODEL_NAME=anthropic/claude-3-5-sonnet

# Example for Local Engine (Gemma 4 via Ollama or vLLM)
# LLM_PROVIDER=local
# LOCAL_API_BASE=http://host.docker.internal:11434/v1
# MODEL_NAME=gemma:4b

# OpenAlgo Configuration (For MCP Server and API execution)
OPENALGO_HOST=http://127.0.0.1:5000
OPENALGO_API_KEY=your_openalgo_api_key

# Data Sources
TRUEDATA_USERNAME=your_truedata_username
TRUEDATA_PASSWORD=your_truedata_password
