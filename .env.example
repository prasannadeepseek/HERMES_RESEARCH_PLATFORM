# =============================================================================
# Hermes Research Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
#
# For the full setup guide, see docs/01_system_setup.md
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Engine Configuration
# -----------------------------------------------------------------------------
LLM_PROVIDER=openrouter

# OpenRouter (cloud LLM — recommended for best results)
OPENROUTER_API_KEY=your_openrouter_api_key
MODEL_NAME=anthropic/claude-3-5-sonnet

# Local LLM via Ollama or vLLM (uncomment to use instead of OpenRouter)
# LLM_PROVIDER=local
# LOCAL_API_BASE=http://host.docker.internal:11434/v1
# MODEL_NAME=gemma:4b

# -----------------------------------------------------------------------------
# OpenAlgo Configuration
# -----------------------------------------------------------------------------
# The OpenAlgo broker gateway runs as a SEPARATE Docker service on hermes_net.
# Hermes communicates with it via REST API only — no file mounts needed.
#
# Docker (root docker-compose): OPENALGO_HOST is set automatically to http://openalgo:5000
# Local dev (no Docker):        Set OPENALGO_HOST=http://127.0.0.1:5000
#
# Get your OPENALGO_API_KEY from the OpenAlgo web UI after first-time setup:
#   http://localhost:5000 → Login → API Keys → Generate
#
# Configured brokers: Zerodha, Upstox (set in openalgo/.env)
OPENALGO_HOST=http://openalgo:5000
OPENALGO_API_KEY=your_openalgo_api_key_from_ui

# -----------------------------------------------------------------------------
# Optional Data Sources
# -----------------------------------------------------------------------------
# TrueData (premium Indian market data — optional, used as fallback)
TRUEDATA_USERNAME=your_truedata_username
TRUEDATA_PASSWORD=your_truedata_password
